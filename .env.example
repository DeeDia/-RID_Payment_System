APP_NAME="NexusPay"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost

# ── Database   ──
# Use a dedicated app_user with minimal privileges (SELECT, INSERT, UPDATE only)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexuspay
DB_USERNAME=app_user
DB_PASSWORD=

# ── Session   ───
# Use 'database' for server-side session storage (enables real-time revocation)
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

# ── Cache  ──
# Redis recommended for rate limiter storage
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Logging  
# Log to daily files; never log passwords or sensitive PII
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Mail  ───
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@nexuspay.co.za"
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite  ───
VITE_APP_NAME="${APP_NAME}"
